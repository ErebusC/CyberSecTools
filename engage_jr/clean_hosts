#!/bin/bash

file="$1"
new_loc="${2:-$(pwd)}"

if [[ -z "$file" ]]; then
	echo "ERROR: no host file provided" >&2
	echo "usage: clean_hosts <hosts_file> [output_dir]" >&2
	exit 1
fi

if [[ ! -f "$file" ]]; then
	echo "ERROR: file not found: $file" >&2
	exit 1
fi

mkdir -p "$new_loc"

# Truncate output files at the start so re-runs don't accumulate stale data
: > "${new_loc}/hosts"
: > "${new_loc}/nohttp_hosts"
: > "${new_loc}/http_hosts"

# Strips HTTP/HTTPS scheme and any trailing path, writes to hosts and nohttp_hosts
remove_http() {
	local stripped
	stripped=$(sed -E -e 's|https?://||' -e 's|/.*||' <<< "$1")
	echo "$stripped" >> "${new_loc}/hosts"
	echo "$stripped" >> "${new_loc}/nohttp_hosts"
}

expand_range() {
	local host="$1"

	# IP range: 10.10.10.1-5
	if [[ "$host" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}-[0-9]{1,3}$ ]]; then
		local base_ip range_part range_start range_end
		base_ip="${host%.*}"          # e.g. 10.10.10
		range_part="${host##*.}"      # e.g. 2-5
		range_start="${range_part%-*}" # e.g. 2
		range_end="${range_part#*-}"   # e.g. 5
		for i in $(seq "$range_start" "$range_end"); do
			echo "${base_ip}.${i}" >> "${new_loc}/hosts"
		done

	# CIDR notation: 10.10.10.0/24
	elif [[ "$host" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}/[0-9]{1,2}$ ]]; then
		nmap -sL -n "$host" 2>/dev/null | grep 'Nmap scan report' | awk '{print $NF}' >> "${new_loc}/hosts"

	# Single IP
	elif [[ "$host" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]; then
		echo "$host" >> "${new_loc}/hosts"

	else
		echo "WARNING: unrecognised host format: $host" >&2
	fi
}

while read -r host; do
	[[ -z "$host" ]] && continue

	if [[ "$host" =~ ^([0-9]{1,3}\.){3} ]]; then
		expand_range "$host"
	elif [[ "$host" =~ ^https?:// ]]; then
		echo "$host" >> "${new_loc}/http_hosts"
		remove_http "$host"
	else
		echo "$host" >> "${new_loc}/hosts"
	fi
done < "$file"

# Sort and deduplicate all output files in place
for f in hosts nohttp_hosts http_hosts; do
	[[ -s "${new_loc}/${f}" ]] && sort -u "${new_loc}/${f}" -o "${new_loc}/${f}"
done
