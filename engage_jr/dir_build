#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

[[ -f "${SCRIPT_DIR}/config" ]] || { echo "ERROR: config not found at ${SCRIPT_DIR}/config" >&2; return 1 2>/dev/null || exit 1; }
source "${SCRIPT_DIR}/config"

help() {
	echo "dir_build <flag> <name>"
	echo ""
	echo "  -t <name>   Create a lab directory within /${ENGAGEJR_THM_SUBDIR}"
	echo "  -b <name>   Create a lab directory within /${ENGAGEJR_HTB_SUBDIR}"
	echo "  -p <name>   Create a lab directory within /${ENGAGEJR_PS_SUBDIR}"
	echo "  -e <name>   Create a directory within /${ENGAGEJR_EXAM_SUBDIR}"
	echo "  -w <name>   Create directories within /${ENGAGEJR_WORK_SUBDIR} (includes burp, nmap, nessus, other)"
	echo "  -h          This page"
	echo "  -v          Version"
}

version() {
	echo "version 2.0"
	echo "Built by Daniel Roberts"
}

category=""
lab=""

while getopts ":hvt:b:e:p:w:" option; do
	case $option in
		h) help; return 0 2>/dev/null || exit 0 ;;
		v) version; return 0 2>/dev/null || exit 0 ;;
		t) category="${ENGAGEJR_THM_SUBDIR}";  lab="$OPTARG" ;;
		b) category="${ENGAGEJR_HTB_SUBDIR}";  lab="$OPTARG" ;;
		e) category="${ENGAGEJR_EXAM_SUBDIR}"; lab="$OPTARG" ;;
		p) category="${ENGAGEJR_PS_SUBDIR}";   lab="$OPTARG" ;;
		w) category="${ENGAGEJR_WORK_SUBDIR}"; lab="$OPTARG" ;;
		:) echo "ERROR: option -${OPTARG} requires an argument" >&2; help; return 1 2>/dev/null || exit 1 ;;
		\?) echo "ERROR: invalid option -${OPTARG}" >&2; help; return 1 2>/dev/null || exit 1 ;;
	esac
done

if [[ -z "$category" || -z "$lab" ]]; then
	echo "ERROR: no options were passed" >&2
	help
	return 1 2>/dev/null || exit 1
fi

export base="${ENGAGEJR_BASE_DIR}/${category}/${lab}"

if [[ -d "$base" ]]; then
	echo "Note: directory already exists: ${base}"
else
	mkdir -p "$base" || { echo "ERROR: cannot create ${base}" >&2; return 1 2>/dev/null || exit 1; }
fi

if [[ "$category" == "${ENGAGEJR_WORK_SUBDIR}" ]]; then
	for subdir in "${ENGAGEJR_SUBDIRS[@]}"; do
		mkdir -p "${base}/${subdir}"
	done
	"${SCRIPT_DIR}/burper" "$base" "$lab" &
fi
