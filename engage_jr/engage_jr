#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

[[ -f "${SCRIPT_DIR}/config" ]] || { echo "ERROR: config not found at ${SCRIPT_DIR}/config" >&2; exit 1; }
source "${SCRIPT_DIR}/config"

help() {
	echo "usage: engage_jr <job_name> <hosts_file>"
	echo "       engage_jr -l [category]"
	echo ""
	echo "  -l [category]  List existing engagements (optionally filter by category)"
	echo "  -h             This page"
}

list_engagements() {
	local category="$1"

	if [[ -n "$category" ]]; then
		local cat_dir="${ENGAGEJR_BASE_DIR}/${category}"
		if [[ ! -d "$cat_dir" ]]; then
			echo "ERROR: category not found: ${cat_dir}" >&2
			exit 1
		fi
		echo "Engagements in [${category}]:"
		ls -1 "$cat_dir" 2>/dev/null | sed 's/^/  /'
	else
		echo "All engagements under ${ENGAGEJR_BASE_DIR}:"
		for cat in "$ENGAGEJR_WORK_SUBDIR" "$ENGAGEJR_HTB_SUBDIR" \
		           "$ENGAGEJR_THM_SUBDIR" "$ENGAGEJR_EXAM_SUBDIR" \
		           "$ENGAGEJR_PS_SUBDIR"; do
			local cat_dir="${ENGAGEJR_BASE_DIR}/${cat}"
			if [[ -d "$cat_dir" ]]; then
				echo ""
				echo "  [${cat}]"
				ls -1 "$cat_dir" 2>/dev/null | sed 's/^/    /'
			fi
		done
	fi
}

# Handle flags
case "$1" in
	-h) help; exit 0 ;;
	-l) list_engagements "$2"; exit 0 ;;
esac

# Validate positional args
if [[ -z "$1" || -z "$2" ]]; then
	echo "ERROR: job name and hosts file are required" >&2
	help
	exit 1
fi

job="$1"

# Resolve hosts file path (handle both relative and absolute)
if [[ "$2" = /* ]]; then
	hosts="$2"
else
	hosts="$(pwd)/$2"
fi

if [[ ! -f "$hosts" ]]; then
	echo "ERROR: hosts file not found: $hosts" >&2
	exit 1
fi

# Build directory structure (sets and exports $base)
source "${SCRIPT_DIR}/dir_build" -w "$job"

if [[ -z "$base" ]]; then
	echo "ERROR: dir_build failed to set base directory" >&2
	exit 1
fi

cd "$base"
"${SCRIPT_DIR}/clean_hosts" "$hosts" "$base"

exec $SHELL
